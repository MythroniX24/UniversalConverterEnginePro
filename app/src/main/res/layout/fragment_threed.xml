<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="#0D1117">
    <android.opengl.GLSurfaceView android:id="@+id/glSurface"
        android:layout_width="match_parent" android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toTopOf="@id/cardControls"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
    <TextView android:id="@+id/tvModelInfo"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Load an OBJ, FBX, or STL file" android:textColor="#FFFFFFFF"
        android:textSize="12sp" android:background="#AA000000" android:padding="8dp"
        android:layout_margin="12dp"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
    <ProgressBar android:id="@+id/progressBar3d" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:visibility="gone"
        android:indeterminateTint="@android:color/white"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toTopOf="@id/cardControls"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
    <com.google.android.material.card.MaterialCardView android:id="@+id/cardControls"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        app:cardBackgroundColor="#FF161B22" app:cardCornerRadius="0dp"
        app:layout_constraintBottom_toBottomOf="parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <com.google.android.material.button.MaterialButton android:id="@+id/btnLoad"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:layout_marginEnd="4dp" android:text="Load Model" android:textColor="@android:color/white"
                    app:backgroundTint="#FF0D419D"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnConvertObj"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:layout_marginStart="4dp" android:text="Convert"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="#FF0D419D" android:textColor="@android:color/white"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton android:id="@+id/btnReset"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Reset" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="#FF30363D" android:textColor="#FF8B949E" android:layout_marginEnd="4dp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnWireframe"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Wireframe" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="#FF30363D" android:textColor="#FF8B949E" android:layout_marginStart="4dp"/>
                <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/btnAutoRotate"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Auto" android:textColor="#FF8B949E" android:layout_marginStart="8dp"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
    <LinearLayout android:id="@+id/cardControls2" android:layout_width="0dp" android:layout_height="0dp"
        android:visibility="gone" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
